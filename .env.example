# ── Telegram credentials ──────────────────────────────────────
# Get these from https://my.telegram.org
API_ID=
API_HASH=

# ── Target group/channel to forward messages to ───────────────
# Use a negative integer for groups/channels e.g. -1001234567890
TARGET_GROUP=

# ── Session file name (no extension needed) ───────────────────
SESSION_NAME=session

# ── File paths ────────────────────────────────────────────────
DB_PATH=messages.db
LOG_FILE=logger.log

# ── Control bot ───────────────────────────────────────────────
# Create a bot via @BotFather, paste the token here
BOT_TOKEN=
# Your own Telegram user ID (get it from @userinfobot)
OWNER_ID=
